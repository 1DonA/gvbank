# ── Database ──────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./gvbank.db
# For production use PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://user:password@localhost/gvbank

# ── JWT ───────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-very-long-random-string-in-production

# ── SendGrid (real email OTP) ─────────────────────────────
# Get free API key at https://sendgrid.com
SENDGRID_API_KEY=SG.your-api-key-here
FROM_EMAIL=noreply@gvunionbank.com
FROM_NAME=GV Union Bank

# ── Twilio (real SMS OTP) ─────────────────────────────────
# Get free trial at https://twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token-here
TWILIO_PHONE_NUMBER=+15551234567

# ── Admin credentials ─────────────────────────────────────
ADMIN_EMAIL=admin@gvunionbank.com
ADMIN_PASSWORD=Admin@GVBank2026!
